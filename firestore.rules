rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Documentos de usuário — leitura/escrita apenas pelo próprio usuário
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Projetos — leitura por dono ou colaboradores, criação por qualquer usuário autenticado
    match /projects/{projectId} {
      allow read: if request.auth != null && (
        resource.data.owner == request.auth.uid ||
        request.auth.uid in resource.data.collaborators
      );
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.owner == request.auth.uid;
    }

    // Segredos do projeto — NUNCA acessíveis pelo client SDK
    match /project_secrets/{projectId} {
      allow read, write: if false;
    }

    // Índice de roteamento do webhook — somente leitura autenticada
    match /phone_number_lookup/{phoneNumberId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Conversas — leitura por qualquer usuário autenticado
    // Escrita apenas via Admin SDK (rota do webhook)
    match /conversations/{conversationId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Mensagens — leitura por qualquer usuário autenticado
    // Escrita apenas via Admin SDK (rota do webhook)
    match /messages/{messageId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
